# Authentication
NEXT_PUBLIC_JWT_SECRET=your_jwt_secret_here

# API URLs
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000

# Database
MONGODB_URI=mongodb://localhost:27017/guazu

# Email Service (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
NEXT_PUBLIC_SUPPORT_EMAIL=support@guazu.com

# Application
NEXT_PUBLIC_APP_NAME=Guazu 2.0
NEXT_PUBLIC_APP_DESCRIPTION=Plataforma de encuestas
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Environment
NODE_ENV=development 